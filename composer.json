    "type": "neos-carbon",
    "name": "carbon/slideshoweditor",
    "license": "GPL-3.0-or-later",
    "require": {
        "neos/neos-ui": "~9.1.4 || ~9.2",
        "carbon/videoplatformeditor": "^1.0"
